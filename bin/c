#!/bin/bash
#
# c - per-window provider launcher for Claude Code
#
# Usage:
#   c <number> [claude args...]                 launch with provider <number>
#   c team <leader#> <teammate#> [args...]      team mode: split leader/teammates
#   c s                                         show config file
#   c router status|stop [all|team|protocol]    manage local routers
#

# Resolve symlinks so the npm global bin shim finds the real package dir.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PKG_DIR="$(cd "$BIN_DIR/.." && pwd)"

CONFIG_DIR="${CLAUDE_LANES_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-lanes}"
CONFIG_FILE="$CONFIG_DIR/config.env"
STATE_DIR="${CLAUDE_LANES_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-lanes}"
ROUTER_PID_DIR="$STATE_DIR/routers"
ROUTER_SCRIPT="$PKG_DIR/lib/router.js"
AUTH_HELPER="$BIN_DIR/auth-helper.sh"
C_SETTINGS="${CLAUDE_LANES_SETTINGS:-$HOME/.claude/settings-lanes.json}"
CLAUDE_BIN="${CLAUDE_LANES_CLAUDE_BIN:-claude}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

die() {
    echo -e "${RED}error: $1${NC}" >&2
    exit 1
}

check_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo -e "${YELLOW}No config found, creating a template...${NC}"
        mkdir -p "$CONFIG_DIR"
        cp "$PKG_DIR/config.env.example" "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"
        echo -e "${GREEN}Created: $CONFIG_FILE${NC}"
        echo -e "${YELLOW}Edit it, then run: c 0${NC}"
        exit 0
    fi
}

# Create ~/.claude/settings-lanes.json (apiKeyHelper) on first run.
ensure_settings() {
    [[ -f "$C_SETTINGS" ]] && return 0
    mkdir -p "$(dirname "$C_SETTINGS")"
    printf '{"apiKeyHelper": "%s"}\n' "$AUTH_HELPER" > "$C_SETTINGS"
    echo -e "${GREEN}Created Claude settings: $C_SETTINGS${NC}"
}

read_config_field() {
    local num="$1"
    local field="$2"
    grep "^CONFIG_${num}_${field}=" "$CONFIG_FILE" | cut -d'=' -f2-
}

# Global (non-numbered) config key, e.g. CLAUDE_ARGS=--dangerously-skip-permissions
read_global_field() {
    grep "^$1=" "$CONFIG_FILE" | cut -d'=' -f2-
}

show_help() {
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}  c — per-window provider launcher for Claude Code${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "Usage:"
    echo -e "  ${GREEN}c <number> [claude args...]${NC}                 launch with provider <number>"
    echo -e "  ${GREEN}c team <leader#> <teammate#> [args...]${NC}      team mode: leader and teammates on different providers"
    echo -e "  ${GREEN}c s${NC}                                         show config file"
    echo -e "  ${GREEN}c router status|stop${NC}                        manage local routers"
    echo ""
    echo -e "Paths:"
    echo -e "  ${BLUE}config  ${NC} $CONFIG_FILE"
    echo -e "  ${BLUE}state   ${NC} $STATE_DIR"
    echo -e "  ${BLUE}settings${NC} $C_SETTINGS"
    echo ""
    echo "Configured lanes:"

    if [[ -f "$CONFIG_FILE" ]]; then
        local numbers=$(grep -oE "CONFIG_[0-9]+_BASE_URL" "$CONFIG_FILE" | grep -oE "[0-9]+" | sort -un)
        for num in $numbers; do
            local base_url=$(read_config_field "$num" "BASE_URL")
            local model=$(read_config_field "$num" "MODEL")
            if [[ -n "$base_url" ]]; then
                local label="${model:-${base_url##*/}}"
                echo -e "  ${GREEN}$num${NC} → ${label} (${base_url})"
            fi
        done
    else
        echo -e "  ${YELLOW}no config yet — run any 'c <number>' to create a template${NC}"
    fi

    echo ""
    echo "Examples:"
    echo -e "  ${GREEN}c 0${NC}             # this window runs provider 0, forever"
    echo -e "  ${GREEN}c 2 --resume${NC}    # provider 2, resume last session"
    echo -e "  ${GREEN}c team 2 0${NC}      # leader on provider 2, teammates on provider 0"
    echo ""
}

# ──────────────────────────────────────────
# router management
# ──────────────────────────────────────────

find_free_port() {
    local port=3100
    while lsof -iTCP:"$port" -sTCP:LISTEN -t &>/dev/null; do
        (( port++ ))
    done
    echo "$port"
}

# Print "<name> <pid>" for every live router. Name "3100" = team mode,
# "openai-4100" = protocol mode.
router_list_alive() {
    mkdir -p "$ROUTER_PID_DIR"
    for f in "$ROUTER_PID_DIR"/*.pid; do
        [[ -f "$f" ]] || continue
        local pid name
        pid=$(cat "$f")
        name="${f##*/}"
        name="${name%.pid}"
        if kill -0 "$pid" 2>/dev/null; then
            echo "$name $pid"
        else
            rm -f "$f"
        fi
    done
}

_router_kind() {
    case "$1" in
        *-*) echo "protocol(${1%%-*})" ;;
        *)   echo "team" ;;
    esac
}

router_stop_all() {
    local filter="${1:-all}"
    local found=0
    while read -r name pid; do
        local kind
        kind=$(_router_kind "$name")
        local keep=0
        case "$filter" in
            all)      keep=1 ;;
            team)     [[ "$kind" == "team" ]] && keep=1 ;;
            protocol) [[ "$kind" == "protocol"* ]] && keep=1 ;;
            *)        [[ "$kind" == "protocol($filter)" ]] && keep=1 ;;
        esac
        [[ $keep -eq 0 ]] && continue
        kill "$pid" 2>/dev/null
        rm -f "${ROUTER_PID_DIR}/${name}.pid"
        rm -rf "${ROUTER_PID_DIR}/${name}.lock" 2>/dev/null
        echo -e "${YELLOW}router stopped (kind=$kind name=$name pid=$pid)${NC}"
        found=1
    done < <(router_list_alive)
    [[ $found -eq 0 ]] && echo -e "${YELLOW}no running routers (filter=$filter)${NC}"
}

# Team-mode router: every `c team` gets its own port.
router_start() {
    local leader_url="$1"
    local leader_token="$2"
    local teammate_url="$3"
    local teammate_token="$4"

    [[ ! -f "$ROUTER_SCRIPT" ]] && die "router.js not found: $ROUTER_SCRIPT"
    command -v node &>/dev/null || die "node not found (claude-lanes requires Node 18+)"
    mkdir -p "$ROUTER_PID_DIR"

    local port
    port=$(find_free_port)
    local log_file="${ROUTER_PID_DIR}/${port}.log"

    ROUTER_PORT="$port" \
    ROUTER_STATE_DIR="$ROUTER_PID_DIR" \
    ROUTER_LEADER_URL="$leader_url" \
    ROUTER_LEADER_TOKEN="$leader_token" \
    ROUTER_TEAMMATE_URL="$teammate_url" \
    ROUTER_TEAMMATE_TOKEN="$teammate_token" \
    ROUTER_TEAMMATE_MODEL="$teammate_model" \
    node "$ROUTER_SCRIPT" > "$log_file" 2>&1 &

    local pid=$!
    echo "$pid" > "${ROUTER_PID_DIR}/${port}.pid"

    local max_wait=50 waited=0
    while [[ $waited -lt $max_wait ]]; do
        if curl -sf "http://127.0.0.1:${port}/" > /dev/null 2>&1; then
            ROUTER_ALLOCATED_PORT="$port"
            return 0
        fi
        sleep 0.1
        (( waited++ ))
    done

    echo -e "${RED}router startup timed out, log:${NC}"
    cat "$log_file"
    die "router failed to start"
}

# Protocol-mode router: shared across `c` processes, fixed port per protocol.
# Lock: atomic mkdir (macOS friendly, no flock dependency).
router_acquire_or_start() {
    local protocol="$1"
    local upstream_url="$2"
    local upstream_token="$3"
    local model_override="${4:-}"

    local port
    case "$protocol" in
        openai) port=4100 ;;
        *)      die "unsupported router protocol: $protocol" ;;
    esac

    local name="${protocol}-${port}"
    local pid_file="${ROUTER_PID_DIR}/${name}.pid"
    local lock_dir="${ROUTER_PID_DIR}/${name}.lock"
    local log_file="${ROUTER_PID_DIR}/${name}.log"

    [[ ! -f "$ROUTER_SCRIPT" ]] && die "router.js not found: $ROUTER_SCRIPT"
    command -v node &>/dev/null || die "node not found (claude-lanes requires Node 18+)"
    mkdir -p "$ROUTER_PID_DIR"

    # fast path: alive + healthy → reuse
    if [[ -f "$pid_file" ]]; then
        local existing_pid
        existing_pid=$(cat "$pid_file" 2>/dev/null || echo "")
        if [[ -n "$existing_pid" ]] && kill -0 "$existing_pid" 2>/dev/null; then
            if curl -sf "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
                ROUTER_ALLOCATED_PORT="$port"
                return 0
            fi
            kill "$existing_pid" 2>/dev/null
            sleep 0.5
        fi
        rm -f "$pid_file"
    fi

    # slow path: atomic mkdir lock + double check + spawn
    if ! mkdir "$lock_dir" 2>/dev/null; then
        local waited=0
        while [[ $waited -lt 50 ]]; do
            if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file" 2>/dev/null)" 2>/dev/null \
               && curl -sf "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
                ROUTER_ALLOCATED_PORT="$port"
                return 0
            fi
            sleep 0.1
            (( waited++ ))
        done
        die "could not acquire router lock: $lock_dir (another c is starting it)"
    fi
    trap "rmdir '$lock_dir' 2>/dev/null || true" RETURN

    if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file" 2>/dev/null)" 2>/dev/null \
       && curl -sf "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
        ROUTER_ALLOCATED_PORT="$port"
        return 0
    fi

    ROUTER_PORT="$port" \
    ROUTER_STATE_DIR="$ROUTER_PID_DIR" \
    ROUTER_PROTOCOL="$protocol" \
    ROUTER_UPSTREAM_URL="$upstream_url" \
    ROUTER_UPSTREAM_TOKEN="$upstream_token" \
    ROUTER_TEAMMATE_MODEL="$model_override" \
    node "$ROUTER_SCRIPT" > "$log_file" 2>&1 &

    local pid=$!
    echo "$pid" > "$pid_file"

    local max_wait=50 waited=0
    while [[ $waited -lt $max_wait ]]; do
        if curl -sf "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
            ROUTER_ALLOCATED_PORT="$port"
            return 0
        fi
        sleep 0.1
        (( waited++ ))
    done

    echo -e "${RED}protocol router startup timed out, log:${NC}"
    cat "$log_file"
    kill "$pid" 2>/dev/null
    rm -f "$pid_file"
    die "protocol router failed to start"
}

# ──────────────────────────────────────────
# single-provider launch
# ──────────────────────────────────────────

start_single() {
    local config_num="$1"
    shift

    check_config
    ensure_settings

    local base_url auth_token compact_window model effort protocol

    base_url=$(read_config_field "$config_num" "BASE_URL")
    auth_token=$(read_config_field "$config_num" "AUTH_TOKEN")
    compact_window=$(read_config_field "$config_num" "COMPACT_WINDOW")
    model=$(read_config_field "$config_num" "MODEL")
    effort=$(read_config_field "$config_num" "EFFORT")
    protocol=$(read_config_field "$config_num" "PROTOCOL")
    protocol="${protocol:-anthropic}"

    [[ -z "$base_url" ]]    && die "lane $config_num: BASE_URL not found"
    [[ -z "$auth_token" ]]  && die "lane $config_num: AUTH_TOKEN not found"

    local model_name="${model:-${base_url##*/}}"

    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}🚀 Claude Code [lane $config_num]${NC}"
    echo -e "${BLUE}   API:      $base_url${NC}"
    echo -e "${YELLOW}   Model:    $model_name${NC}"
    echo -e "${MAGENTA}   Protocol: $protocol${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    if [[ "$protocol" == "openai" ]]; then
        ROUTER_ALLOCATED_PORT=""
        router_acquire_or_start "$protocol" "$base_url" "$auth_token" "$model"
        echo -e "${GREEN}✓ protocol router ready (port ${ROUTER_ALLOCATED_PORT} → $base_url)${NC}"
        echo ""

        # everything goes through the local router
        export ANTHROPIC_BASE_URL="http://127.0.0.1:${ROUTER_ALLOCATED_PORT}"
        # the real token reaches the router via apiKeyHelper
        export CLAUDE_AUTH_TOKEN="$auth_token"
        unset ANTHROPIC_AUTH_TOKEN
        export CLAUDE_PROTOCOL="openai"
        export CLAUDE_MODEL_LABEL="$model_name"
    else
        [[ "$protocol" != "anthropic" ]] && die "unknown PROTOCOL: $protocol (supported: anthropic / openai)"
        export ANTHROPIC_BASE_URL="$base_url"
        export CLAUDE_AUTH_TOKEN="$auth_token"
        unset ANTHROPIC_AUTH_TOKEN
        export CLAUDE_MODEL_LABEL="$model_name"
    fi

    if [[ -n "$model" ]]; then
        export ANTHROPIC_SMALL_FAST_MODEL="$model"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="$model"
        export ANTHROPIC_DEFAULT_OPUS_MODEL="$model"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="$model"
        echo -e "${YELLOW}   Model override: $model${NC}"
    else
        unset ANTHROPIC_SMALL_FAST_MODEL
        unset ANTHROPIC_DEFAULT_SONNET_MODEL
        unset ANTHROPIC_DEFAULT_OPUS_MODEL
        unset ANTHROPIC_DEFAULT_HAIKU_MODEL
    fi

    if [[ -n "$compact_window" ]]; then
        export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$compact_window"
        echo -e "${BLUE}   Compact: ${compact_window} tokens${NC}"
    else
        unset CLAUDE_CODE_AUTO_COMPACT_WINDOW
    fi

    if [[ -n "$effort" ]]; then
        export CLAUDE_CODE_EFFORT_LEVEL="$effort"
        echo -e "${MAGENTA}   Effort: ${effort}${NC}"
    else
        unset CLAUDE_CODE_EFFORT_LEVEL
    fi

    command -v "$CLAUDE_BIN" &>/dev/null || die "claude not found (npm i -g @anthropic-ai/claude-code)"

    # extra args from config (e.g. CLAUDE_ARGS=--dangerously-skip-permissions)
    local extra_args
    extra_args=$(read_global_field "CLAUDE_ARGS")

    # pass --model explicitly so it wins over any model left in project settings
    local claude_args=(--settings "$C_SETTINGS")
    [[ -n "$model" ]] && claude_args+=(--model "$model")
    [[ -n "$extra_args" ]] && claude_args+=($extra_args)

    exec "$CLAUDE_BIN" "${claude_args[@]}" "$@"
}

# ──────────────────────────────────────────
# team launch
# ──────────────────────────────────────────

start_team() {
    local leader_num="$1"
    local teammate_num="$2"
    shift 2

    check_config
    ensure_settings

    local leader_url leader_token leader_compact leader_model leader_effort
    leader_url=$(read_config_field "$leader_num" "BASE_URL")
    leader_token=$(read_config_field "$leader_num" "AUTH_TOKEN")
    leader_compact=$(read_config_field "$leader_num" "COMPACT_WINDOW")
    leader_model=$(read_config_field "$leader_num" "MODEL")
    leader_effort=$(read_config_field "$leader_num" "EFFORT")

    [[ -z "$leader_url" ]]   && die "leader lane $leader_num: BASE_URL not found"
    [[ -z "$leader_token" ]] && die "leader lane $leader_num: AUTH_TOKEN not found"

    local teammate_url teammate_token teammate_model
    teammate_url=$(read_config_field "$teammate_num" "BASE_URL")
    teammate_token=$(read_config_field "$teammate_num" "AUTH_TOKEN")
    teammate_model=$(read_config_field "$teammate_num" "MODEL")

    [[ -z "$teammate_url" ]]   && die "teammate lane $teammate_num: BASE_URL not found"
    [[ -z "$teammate_token" ]] && die "teammate lane $teammate_num: AUTH_TOKEN not found"

    local leader_label="${leader_model:-${leader_url##*/}}"
    local teammate_label="${teammate_model:-${teammate_url##*/}}"

    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}🚀 Claude Code [team mode]${NC}"
    echo -e "${MAGENTA}   Leader   [${leader_num}]: ${leader_label}${NC}"
    echo -e "${BLUE}             ${leader_url}${NC}"
    echo -e "${YELLOW}   Teammate [${teammate_num}]: ${teammate_label}${NC}"
    echo -e "${BLUE}             ${teammate_url}${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    echo -e "${BLUE}▶ starting team router...${NC}"
    ROUTER_ALLOCATED_PORT=""
    router_start "$leader_url" "$leader_token" "$teammate_url" "$teammate_token"
    echo -e "${GREEN}✓ team router ready (port ${ROUTER_ALLOCATED_PORT})${NC}"
    echo ""

    # compact window and effort follow the leader (it is the main process)
    if [[ -n "$leader_compact" ]]; then
        export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$leader_compact"
        echo -e "${BLUE}   Compact: ${leader_compact} tokens${NC}"
    else
        unset CLAUDE_CODE_AUTO_COMPACT_WINDOW
    fi

    if [[ -n "$leader_effort" ]]; then
        export CLAUDE_CODE_EFFORT_LEVEL="$leader_effort"
        echo -e "${MAGENTA}   Effort: ${leader_effort}${NC}"
    else
        unset CLAUDE_CODE_EFFORT_LEVEL
    fi

    # Leader lane with an explicit MODEL: export the alias overrides so claude
    # accepts a non-claude model name client-side. Teammates inherit these, but
    # the router rewrites teammate model names anyway (ROUTER_TEAMMATE_MODEL).
    # Without an explicit MODEL (claude-family providers), keep passthrough.
    if [[ -n "$leader_model" ]]; then
        export ANTHROPIC_SMALL_FAST_MODEL="$leader_model"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="$leader_model"
        export ANTHROPIC_DEFAULT_OPUS_MODEL="$leader_model"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="$leader_model"
    else
        unset ANTHROPIC_SMALL_FAST_MODEL
        unset ANTHROPIC_DEFAULT_SONNET_MODEL
        unset ANTHROPIC_DEFAULT_OPUS_MODEL
        unset ANTHROPIC_DEFAULT_HAIKU_MODEL
    fi

    export ANTHROPIC_BASE_URL="http://127.0.0.1:${ROUTER_ALLOCATED_PORT}"
    unset ANTHROPIC_AUTH_TOKEN
    # CLAUDE_TEAM_ROLE survives in the leader process but is filtered from
    # spawned teammates — apiKeyHelper uses that to return different tokens,
    # and the router uses the tokens to pick the route.
    export CLAUDE_TEAM_ROLE=leader
    export CLAUDE_MODEL_LABEL="team(${leader_label}+${teammate_label})"

    command -v "$CLAUDE_BIN" &>/dev/null || die "claude not found (npm i -g @anthropic-ai/claude-code)"

    local extra_args
    extra_args=$(read_global_field "CLAUDE_ARGS")
    local claude_args=(--settings "$C_SETTINGS" --teammate-mode tmux)
    # the leader keeps its lane's model name — without this, claude inherits a
    # model from global settings that the leader's provider may reject
    [[ -n "$leader_model" ]] && claude_args+=(--model "$leader_model")
    [[ -n "$extra_args" ]] && claude_args+=($extra_args)

    # no exec here: a trap shuts the router down when claude exits
    _CLEANUP_ROUTER_PORT="$ROUTER_ALLOCATED_PORT"
    _CLEANUP_ROUTER_PID=$(cat "${ROUTER_PID_DIR}/${ROUTER_ALLOCATED_PORT}.pid")

    cleanup() {
        kill "$_CLEANUP_ROUTER_PID" 2>/dev/null
        rm -f "${ROUTER_PID_DIR}/${_CLEANUP_ROUTER_PORT}.pid"
        echo -e "\n${YELLOW}team router stopped (port=${_CLEANUP_ROUTER_PORT})${NC}"
    }
    trap cleanup EXIT INT TERM

    "$CLAUDE_BIN" "${claude_args[@]}" "$@"
}

# ──────────────────────────────────────────
# main
# ──────────────────────────────────────────

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    local cmd="$1"

    if [[ "$cmd" == "s" || "$cmd" == "show" ]]; then
        check_config
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${CYAN}  config  : ${BLUE}$CONFIG_FILE${NC}"
        echo -e "${CYAN}  state   : ${BLUE}$STATE_DIR${NC}"
        echo -e "${CYAN}  settings: ${BLUE}$C_SETTINGS${NC}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        cat "$CONFIG_FILE"
        exit 0
    fi

    if [[ "$cmd" == "router" ]]; then
        local sub="${2:-}"
        local filter="${3:-all}"
        if [[ "$sub" == "stop" ]]; then
            router_stop_all "$filter"
        elif [[ "$sub" == "status" ]]; then
            local count=0
            while read -r name pid; do
                local kind
                kind=$(_router_kind "$name")
                local port="$name"
                [[ "$name" == *-* ]] && port="${name##*-}"
                echo -e "${GREEN}router [$kind] (name=$name port=$port pid=$pid)${NC}"
                curl -sf "http://127.0.0.1:${port}/" 2>/dev/null && echo ""
                (( count++ ))
            done < <(router_list_alive)
            [[ $count -eq 0 ]] && echo -e "${YELLOW}no running routers${NC}"
        else
            echo -e "usage: ${GREEN}c router stop${NC} | ${GREEN}c router status${NC}"
        fi
        exit 0
    fi

    if [[ "$cmd" == "team" ]]; then
        [[ $# -lt 3 ]] && die "usage: c team <leader#> <teammate#> [claude args...]"
        local leader_num="$2"
        local teammate_num="$3"
        shift 3
        [[ "$leader_num" =~ ^[0-9]+$ ]]   || die "leader number must be numeric"
        [[ "$teammate_num" =~ ^[0-9]+$ ]] || die "teammate number must be numeric"
        start_team "$leader_num" "$teammate_num" "$@"
        exit 0
    fi

    if [[ "$cmd" =~ ^[0-9]+$ ]]; then
        shift
        start_single "$cmd" "$@"
        exit 0
    fi

    die "unknown command: $cmd (run c for help)"
}

main "$@"
