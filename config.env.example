# claude-lanes config — one numbered lane per provider.
# Format: CONFIG_<n>_BASE_URL and CONFIG_<n>_AUTH_TOKEN  (n = 0, 1, 2, ...)
# Launch a window with: c <n>

# Lane 0 — example: an Anthropic-compatible provider
CONFIG_0_BASE_URL=https://api.example.com/anthropic
CONFIG_0_AUTH_TOKEN=your-token-here

# Lane 1 — example: official Anthropic API
CONFIG_1_BASE_URL=https://api.anthropic.com
CONFIG_1_AUTH_TOKEN=your-token-here

# Lane 2 — example: an OpenAI-compatible endpoint (vLLM, OpenRouter, ...)
# PROTOCOL=openai routes through the local protocol-translation proxy.
#CONFIG_2_BASE_URL=https://api.example.com/v1
#CONFIG_2_AUTH_TOKEN=your-token-here
#CONFIG_2_PROTOCOL=openai
#CONFIG_2_MODEL=your-model-name

# Per-lane options:
#   CONFIG_<n>_MODEL=...            force a model name (also sets --model)
#   CONFIG_<n>_COMPACT_WINDOW=...   auto-compact threshold in tokens
#   CONFIG_<n>_EFFORT=...           thinking effort: minimal/low/medium/high/max
#   CONFIG_<n>_PROTOCOL=openai      translate to an OpenAI-compatible upstream

# Global options:
#   CLAUDE_ARGS=...                 extra args appended to every claude launch
#CLAUDE_ARGS=
